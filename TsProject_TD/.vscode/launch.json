    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "pwa-node",
            "name": "Puerts 附加到 Unity (9229)",
            "request": "attach",
            "address": "127.0.0.1",
            "port": 9229,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../Assets/Resources/**/*.js"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/../Assets/Resources/**"
            ],
            "localRoot": "${workspaceFolder}/../Assets/Resources",
            "remoteRoot": ""
        }
    ]
}